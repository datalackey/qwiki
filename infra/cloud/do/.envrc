# Pulls secrets from Bitwarden and exports them as the TF_VAR_* Terraform
# expects, so `terraform plan`/`apply` run from this directory never need
# them typed or pasted manually.
#
# Requires: `bw` CLI installed, `bw login` already done once, and the
# `bw_session` function defined in ~/.config/direnv/direnvrc (shared
# across all projects, not repo-specific -- see that file for how it
# caches BW_SESSION across shells instead of re-prompting every `cd`).
#
# Item names match this repo's convention: same name as on the
# credential's origin platform where one exists (see
# feedback_credential_naming_convention); self-generated secrets (like
# the wiki admin password) are prefixed doikayt- for vault consistency.

bw_session

# One `bw list items` call instead of three separate `bw get` calls --
# each `bw` invocation decrypts the whole vault into memory from
# scratch, so fetching once and parsing locally with jq is much faster
# than paying that cost per secret. This call also doubles as the
# session-validity check (bw_session itself no longer makes a separate
# `bw status` call) -- an empty/invalid result here means the cached
# session is stale, so unlock fresh and retry exactly once.
BW_ITEMS="$(bw list items --session "$BW_SESSION" 2>/dev/null)"

if [ -z "$BW_ITEMS" ] || [ "$BW_ITEMS" = "null" ]; then
  export BW_SESSION="$(bw unlock --raw)"
  mkdir -p "$HOME/.cache"
  echo "$BW_SESSION" > "$HOME/.cache/bw_session"
  chmod 600 "$HOME/.cache/bw_session"
  BW_ITEMS="$(bw list items --session "$BW_SESSION")"
fi

export TF_VAR_github_read_token="$(echo "$BW_ITEMS" | jq -r '.[] | select(.name=="doikayt-org-read-token") | .notes')"
export TF_VAR_wiki_admin_password="$(echo "$BW_ITEMS" | jq -r '.[] | select(.name=="doikayt-wiki-admin-password") | .login.password')"
export TF_VAR_do_token="$(echo "$BW_ITEMS" | jq -r '.[] | select(.name=="doikayt-do-api-token") | .notes')"
