PROJECT_ROOT="$PWD"

# Create temp bin directory
TMP_BIN="/tmp/direnv-bin-$(whoami)-qwiki"
mkdir -p "$TMP_BIN"

# Create reload script with PROJECT_ROOT embedded
cat > "$TMP_BIN/reload" << INNER_EOF
#!/usr/bin/env bash
# PROJECT_ROOT is from the environment or fallback
PROJECT_ROOT="\${PROJECT_ROOT:-$PWD}"
bash "\$PROJECT_ROOT/infra/scripts/fresh-install.sh" && \
bash "\$PROJECT_ROOT/infra/scripts/import-content.sh"
INNER_EOF

chmod +x "$TMP_BIN/reload"
PATH_add "$TMP_BIN"

export PROJECT_ROOT
echo "in env rc"
