.idea/

**/node_modules/
**/dist/
*.tsbuildinfo 

coverage/
.nx/
.env


# MediaWiki XML exports (generated artifact, not source)
*.xml

# Scratch / backup files
*.bak
*.old

# Source image assets committed intentionally
!example/**/files/*.png


# MediaWiki images bind mount (created by docker at runtime)
infra/images/

# MediaWiki extensions — cloned at setup time by ensure-extensions.sh, not committed
infra/extensions/

# Playwright output (screenshots, traces, .last-run.json)
test-results/

# Terraform local state/working files -- tfstate contains fully-resolved
# plaintext secrets (tokens, passwords), never commit it. .terraform/ is
# a regenerable provider-plugin cache. terraform.tfvars (if used instead
# of .envrc) may contain real secrets too.
infra/cloud/*/.terraform/
infra/cloud/*/terraform.tfstate
infra/cloud/*/terraform.tfstate.backup
infra/cloud/*/terraform.tfvars
