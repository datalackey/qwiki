{
  "name": "qwiki",
  "version": "0.1.0",
  "description": "Bootstrap a MediaWiki from local Markdown files",
  "bin": {
    "qwiki": "./src/cli.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "qwiki": "npx tsx src/cli.ts",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:e2e": "tsx tests/e2e/e2e.ts",
    "update-markdown-docs": "autogen-markdown-doc update README.md",
    "check-markdown-docs": "autogen-markdown-doc check README.md"
  },
  "type": "module",
  "license": "MIT",
  "dependencies": {
    "gray-matter": "4.0.3",
    "pandoc-wasm": "1.1.0"
  },
  "devDependencies": {
    "@datalackey/autogen-markdown-doc": "^1.4.11",
    "@datalackey/typescript-build-config": "^0.0.13",
    "tsx": "4.23.0",
    "typescript": "~5.4.0",
    "vitest": "^4.1.10"
  }
}
